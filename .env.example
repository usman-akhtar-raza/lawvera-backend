# Server
PORT=4848
BACKEND_PUBLIC_URL=http://localhost:4848
FRONTEND_APP_URL=http://localhost:3000

# MongoDB (platform data)
MONGO_URI=mongodb://localhost:27017/lawvera

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Auth rate limit
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL + pgvector (RAG store)
DATABASE_URL=postgresql://lawvera:lawvera@localhost:5432/lawvera_vectors?schema=public

# Redis + BullMQ
REDIS_URL=redis://localhost:6379
INGESTION_QUEUE_ENABLED=true

# SMTP (for OTP emails — leave blank to log OTPs to console)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Lawvera <noreply@lawvera.pk>

# JazzCash (use the exact test/production host or IP issued during merchant onboarding)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_GATEWAY_URL=http://<jazzcash-gateway-host>/MerchantPortal/transactionmanagement/merchantform
JAZZCASH_TXN_TYPE=MWALLET
JAZZCASH_LANGUAGE=EN
JAZZCASH_PAYMENT_WINDOW_MINUTES=15

# Upload storage
LAW_SOURCE_UPLOAD_DIR=uploads/law-sources

# Admin seed
ADMIN_EMAIL=admin@lawvera.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Lawvera Admin
